# Copy this file to `.env.local` and fill in real values. Never commit `.env.local`.

# ---------------------------------------------------------------------------
# ZOHO
# OAuth + Creator app coordinates. Created in the Zoho API Console
# (https://api-console.zoho.com) under a self-client / server-based app.
# ---------------------------------------------------------------------------
ZOHO_CLIENT_ID=                # OAuth client ID (Zoho API Console > your client > Client ID)
ZOHO_CLIENT_SECRET=            # OAuth client secret (Zoho API Console > your client > Client Secret)
ZOHO_REFRESH_TOKEN=            # Long-lived refresh token (generate via self-client grant; needs ZohoCreator scopes and ZohoCRM.modules.deals.READ for CRM Deals)
ZOHO_ACCOUNTS_URL=             # Accounts host for token exchange, e.g. https://accounts.zoho.com (use the DC matching your account: .com / .eu / .in / .com.au)
ZOHO_API_BASE=                 # Creator API host, e.g. https://www.zohoapis.com (must match the same DC as ZOHO_ACCOUNTS_URL)
ZOHO_ACCOUNT_OWNER=            # Creator app owner login name (URL segment in Creator, e.g. paolo_kidzinkdesign)
ZOHO_APP_NAME=                 # Creator app link name (e.g. product-base-range)
ZOHO_TEST_REPORT=              # Report link name used for the first mirror, e.g. Furniture_Items_List_Report

# ---------------------------------------------------------------------------
# SUPABASE
# Project URL + keys from Supabase dashboard > Project Settings > API.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=          # Project URL, e.g. https://xxxx.supabase.co (Project Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_ANON_KEY=     # Public anon key — safe to expose to the browser (Project Settings > API > Project API keys > anon public)
SUPABASE_SERVICE_ROLE_KEY=         # Service role key — SERVER ONLY, never import in client code (Project Settings > API > Project API keys > service_role)

# ---------------------------------------------------------------------------
# APP SECRETS
# Generated locally; not tied to any external service.
# ---------------------------------------------------------------------------
CRON_SECRET=                   # Shared secret to authenticate Vercel/cron-triggered sync routes. Generate with: openssl rand -hex 32
HEALTH_CHECK_SECRET=           # Shared secret guarding the health-check endpoint. Generate with: openssl rand -hex 32
